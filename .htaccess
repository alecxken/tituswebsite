# ──────────────────────────────────────────────────────────
# Titus Buyers Agent — Apache / cPanel configuration
# ──────────────────────────────────────────────────────────

DirectoryIndex index.php index.html

# ── HTTPS redirect (enable after SSL is active on cPanel) ──
# RewriteEngine On
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── Legacy .html → .php 301 redirects ──
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    RewriteRule ^index\.html$   index.php   [R=301,L]
    RewriteRule ^about\.html$   about.php   [R=301,L]
    RewriteRule ^service\.html$ service.php [R=301,L]
    RewriteRule ^contact\.html$ contact.php [R=301,L]
</IfModule>

# ── Security headers ──
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options  "nosniff"
    Header always set X-Frame-Options         "SAMEORIGIN"
    Header always set Referrer-Policy         "strict-origin-when-cross-origin"
</IfModule>

# ── Protect sensitive files ──
<FilesMatch "\.(sqlite|db|json|log|md|sh|env|yml)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ── Prevent directory listing ──
Options -Indexes

# ── PHP upload limits (adjust if cPanel php.ini takes precedence) ──
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size       12M
</IfModule>
